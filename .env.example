# ============================================================================
# rsmc-engine environment configuration
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in the secrets:   cp .env.example .env
#
# This single file serves BOTH run modes:
#
#   * Docker Compose — `docker compose` auto-loads `.env` and substitutes the
#     ${VAR} references in docker-compose.yml. JWT_SECRET and POSTGRES_PASSWORD
#     have NO defaults there, so compose refuses to start until you set them.
#
#   * No Docker — the engine loads `.env` directly (via dotenvy) and reads the
#     bare vars below. (POSTGRES_* are only used by the Docker path; for a
#     manual setup you encode the password directly in DATABASE_URL.)
#
# Config sources, lowest to highest precedence:
#   1. config.toml (optional)
#   2. APP__SECTION__KEY env vars (double-underscore separator)
#   3. Well-known bare vars (DATABASE_URL, JWT_SECRET, REDIS_URL, PORT)
# ============================================================================

# ---- Secrets (REQUIRED — no safe defaults) ---------------------------------

# Secret used to sign JWTs. MUST be at least 16 characters; the engine refuses
# to start otherwise. Generate a strong value:   openssl rand -hex 32
JWT_SECRET=

# PostgreSQL password.
#   * Docker path: used to provision the postgres container AND composed into
#     the app's DATABASE_URL automatically (they can't drift apart).
#   * No-Docker path: put this same value into DATABASE_URL below yourself.
POSTGRES_PASSWORD=

# ---- Database --------------------------------------------------------------

# No-Docker path: full PostgreSQL connection string. Must match the role,
# password, host, and database you created.
# (The Docker path ignores this and builds the URL from POSTGRES_* instead.)
DATABASE_URL=postgres://rsmc:CHANGE_ME@localhost:5432/rsmc

# Docker path only: override the default DB user / name if you wish.
# POSTGRES_USER=rsmc
# POSTGRES_DB=rsmc

# ---- Docker data directories (Docker path only) ----------------------------

# Where the container stores persistent data on YOUR host. Set these once and
# the Docker stack bind-mounts them automatically — no editing of
# docker-compose.yml needed. Defaults are browsable folders next to the compose
# file (./uploads, ./backups).
#
# IMPORTANT: the container runs as UID 10001, so each directory you point at
# must be writable by that UID. Create them once before `docker compose up`:
#     mkdir -p <dir> && sudo chown 10001:10001 <dir>      # preferred
#   or, if you can't use chown:
#     mkdir -p <dir> && chmod 777 <dir>
#
# These are ignored by the no-Docker path, which writes to APP__STORAGE__* on
# the real filesystem directly.
# UPLOAD_HOST_DIR=./uploads
# BACKUP_HOST_DIR=./backups

# ---- Optional --------------------------------------------------------------

# Enable Redis-backed pub/sub for multi-instance realtime fan-out. Leave unset
# to run single-instance (in-process dispatch only). The Docker stack sets this
# automatically; for a manual single-instance setup, leave it commented out.
# REDIS_URL=redis://localhost:6379

# HTTP listen port (also settable via APP__SERVER__PORT).
PORT=8080

# Comma-separated CORS allowlist. Use "*" only for local dev; in production set
# this to your real frontend origin(s). Consumed by the Docker path as well.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Log filter. Standard `RUST_LOG` syntax; overrides APP__LOGGING__LEVEL.
RUST_LOG=info,rsmc_engine=debug

# ---- Structured overrides (examples; uncomment to use) ---------------------

# APP__SERVER__HOST=0.0.0.0
# APP__SERVER__CORS_ORIGINS=https://app.example.com,https://admin.example.com
# APP__SERVER__MAX_BODY_BYTES=26214400          # 25 MiB
# APP__DATABASE__MAX_CONNECTIONS=20
# APP__DATABASE__MIN_CONNECTIONS=2
# APP__DATABASE__ACQUIRE_TIMEOUT_SECS=10
# APP__DATABASE__AUTO_MIGRATE=true
# APP__AUTH__ACCESS_TOKEN_TTL_SECS=3600         # 1 hour
# APP__AUTH__REFRESH_TOKEN_TTL_SECS=2592000     # 30 days
# APP__STORAGE__UPLOAD_DIR=./uploads
# APP__STORAGE__MAX_FILE_BYTES=26214400         # 25 MiB
# APP__LOGGING__FORMAT=text                     # text | json
# APP__LOGGING__LEVEL=info
